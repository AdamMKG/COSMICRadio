[Desktop Entry]
Name=Radio
Comment=Internet radio streaming applet for COSMIC panel
Type=Application
Exec=cosmic-radio
Terminal=false
Categories=COSMIC;
Keywords=COSMIC;radio;audio;streaming;
Icon=radio_icon
StartupNotify=true

# Required for COSMIC panel to recognize this as an applet
NoDisplay=true
X-CosmicApplet=true
X-CosmicHoverPopup=Auto
X-HostWaylandDisplay=true
X-OverflowPriority=10
